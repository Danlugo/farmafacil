# Database — SQLite for local dev, Postgres for production
# SQLite (default):
DATABASE_URL=sqlite+aiosqlite:///farmafacil.db
# PostgreSQL:
# DATABASE_URL=postgresql+asyncpg://farmafacil:farmafacil@localhost:5432/farmafacil

# API
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO

# Scraper
SCRAPER_TIMEOUT=30

# WhatsApp Business API (from developers.facebook.com)
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_API_TOKEN=your_api_token
WHATSAPP_VERIFY_TOKEN=farmafacil_verify_2026

# LLM (Claude Haiku for conversational fallback — optional)
# Get your key at console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key
LLM_MODEL=claude-haiku-4-20250514
