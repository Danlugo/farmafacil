# Database — SQLite for local dev, Postgres for production
# SQLite (default):
DATABASE_URL=sqlite+aiosqlite:///farmafacil.db
# PostgreSQL:
# DATABASE_URL=postgresql+asyncpg://farmafacil:YOUR_PASSWORD@localhost:5432/farmafacil
# POSTGRES_PASSWORD is used by docker-compose.yml for the db service
POSTGRES_PASSWORD=your_postgres_password

# API
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO

# Scraper
SCRAPER_TIMEOUT=30

# Farmatodo Algolia API (from Farmatodo's frontend network requests)
ALGOLIA_APP_ID=your_algolia_app_id
ALGOLIA_API_KEY=your_algolia_api_key
ALGOLIA_INDEX=products-venezuela

# WhatsApp Business API (from developers.facebook.com)
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_API_TOKEN=your_api_token
WHATSAPP_VERIFY_TOKEN=your_verify_token
WHATSAPP_APP_SECRET=your_app_secret

# LLM (Claude Haiku for conversational fallback — optional)
# Get your key at console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key
LLM_MODEL=claude-haiku-4-20250514

# OpenAI Whisper API (voice message transcription)
OPENAI_API_KEY=your_openai_api_key

# Web search (Brave API — admin chat tool, optional)
BRAVE_SEARCH_API_KEY=your_brave_api_key

# Admin dashboard
ADMIN_USERNAME=your_admin_username
ADMIN_PASSWORD=your_admin_password
ADMIN_SECRET_KEY=your_secret_key
